{
  "name": "pdfforge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "100% client-side PDF editor and builder",
  "scripts": {
    "copy-assets": "node scripts/copy-pdfjs-assets.mjs",
    "predev": "npm run copy-assets",
    "dev": "vite",
    "prebuild": "npm run copy-assets",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.9"
  }
}
